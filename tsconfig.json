{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"noErrorTruncation": true,

		"paths": {
			"@components/*": ["./src/components/*"],
			"@assets/*": ["./src/assets/*"],
			"@images/*": ["./portfolio-static/assets/images/*"],
			"@videos/*": ["./portfolio-static/assets/videos/*"],
			"@layouts/*": ["./src/layouts/*"]
		},
		"plugins": [
			{
				"name": "@astrojs/ts-plugin"
			}
		]
	}
}
