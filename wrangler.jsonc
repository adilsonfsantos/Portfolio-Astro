{
	"compatibility_date": "2026-03-10",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "adilsonsantos",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
		"not_found_handling": "404-page",
	},
	"preview_urls": true,
	"observability": {
		"enabled": true,
	},
}
