---
import { site_author_email } from "../consts";
import { encodeEmail } from "../utils/encodeEmail";
---

<section class="contato" id="contato">
	<div class="contato__gradient"></div>
	<div class="contato__content">
		<h2 class="contato__cta">Vamos conversar!</h2>
		<p class="contato__subtitle">
			Se quiser falar sobre um projeto ou precisa de alguém para ajudar na sua
			equipe, é só chamar por aqui:<br />
			<a
				href={"mailto:" + encodeEmail(site_author_email)}
				class="contato__email">
				<b class="contato__hidden">blocked</b>{site_author_email}</a
			>
		</p>
	</div>
</section>
