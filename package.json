{
	"name": "portfolio-astro",
	"description": "Portfolio of Adilson Santos using Astro",
	"type": "module",
	"version": "0.0.1",
	"engines": {
		"node": ">=24 <25"
	},
	"private": true,
	"browserslist": [
		"defaults"
	],
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"typecheck": "astro check",
		"eslint": "eslint . --cache --cache-location .cache/eslint",
		"stylelint": "stylelint 'src/**/*.{css,scss}' --cache --cache-location .cache/stylelint",
		"format": "prettier --check . --cache --cache-location .cache/prettier",
		"check": "npm run typecheck && npm run eslint && npm run stylelint && npm run format",
		"ci": "npm run check && npm run build",
		"csp": "node scripts/generate-csp-hashes.ts",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,astro,mdx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{scss,css}": [
			"stylelint --fix",
			"prettier --write"
		],
		"*.astro": [
			"node scripts/generate-csp-hashes.ts"
		]
	},
	"dependencies": {
		"@astrojs/mdx": "^7.0.0",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"astro": "^7.0.3",
		"astro-compressor": "^1.3.0",
		"sass": "^1.101.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/ts-plugin": "^1.10.9",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.0.1",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-astro": "^2.1.1",
		"eslint-plugin-mdx": "^3.8.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.8.5",
		"prettier-plugin-astro": "^0.14.1",
		"stylelint": "^17.14.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-scss": "^7.2.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"undici-types": "^8.5.0"
	}
}
